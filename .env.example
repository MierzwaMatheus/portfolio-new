# =============================================================================
# FRONTEND ENV (.env) — lido pelo Vite em build time / runtime do browser
# =============================================================================

# URL do deployment Convex (obrigatório)
VITE_CONVEX_URL=your_convex_deployment_url

# Usado em scripts de build estático (SSG/fetch durante o build)
CONVEX_URL=your_convex_deployment_url
CONVEX_DEPLOY_KEY=your_convex_deploy_key

# URL canônica do site — usado no RSS feed e sitemap
SITE_URL=https://yoursite.com


# =============================================================================
# CONVEX ENV — configurar via: npx convex env set KEY value
# Essas variáveis NÃO vão para o .env local; vivem no servidor Convex.
# =============================================================================

# Segredo para os endpoints de importação CSV via HTTP
# IMPORT_SECRET=random-secret-for-csv-import

# Webhook do Stripe (obrigatório se o plugin de pagamentos estiver ativo)
# STRIPE_WEBHOOK_SECRET=whsec_...

# Token de autenticação do webhook Asaas (obrigatório — retorna 500 se ausente)
# ASAAS_WEBHOOK_TOKEN=your-asaas-webhook-token

# Segredo opcional para o webhook de deploy do Vercel
# VERCEL_WEBHOOK_SECRET=random-secret

# Pepper para fingerprint de API keys no playground (obrigatório — retorna 500 se ausente)
# PLAYGROUND_KEY_PEPPER=random-pepper-min-32-chars

# Habilita o bootstrap do usuário root na primeira execução.
# Defina como "true" apenas durante o setup inicial e remova em seguida.
# BOOTSTRAP_ALLOWED=true
